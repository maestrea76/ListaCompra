---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Tu Compra' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#2aa063" />
    <!-- Favicon SVG moderno (Chrome, Edge, Firefox, Safari 14+). -->
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <!-- Algunos navegadores antiguos al guardar marcadores buscan rel='shortcut icon'. -->
    <link rel="shortcut icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <!-- iOS Home Screen / iPadOS bookmark: necesita un PNG/SVG cuadrado. -->
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />
    <link rel="mask-icon" href={`${base}favicon.svg`} color="#2aa063" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <title>{title}</title>
    <!-- Aplicar tema antes de pintar para evitar parpadeo -->
    <script is:inline>
      try {
        const raw = localStorage.getItem('tucompra:state:v1');
        const t = raw ? (JSON.parse(raw)?.profile?.theme ?? 'system') : 'system';
        const dark = t === 'dark' || (t === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
      } catch {}
    </script>
  </head>
  <body>
    <slot />
    <footer class="text-center text-xs py-6 mt-8 px-4"
      style="color: var(--fg-muted);">
      Tu Compra v.0.1 por <strong>maestrea</strong>
    </footer>
  </body>
</html>

---
import Layout from '../../layouts/Layout.astro';
import ListView from '../../components/list/ListView.svelte';
import { STORES_SEED } from '../../lib/data/stores';

// Pre-genera una página por cada tienda del seed (para output: 'static').
// Las tiendas creadas por el usuario en runtime se gestionan client-side
// con la misma ruta — al ser SPA tras la hidratación funcionan también.
export function getStaticPaths() {
  return STORES_SEED.map((s) => ({ params: { storeId: s.id } }));
}

const { storeId } = Astro.params;
---

<Layout title={`Lista — ${storeId}`}>
  <main class="mx-auto max-w-3xl px-4 py-6">
    <ListView client:only="svelte" storeId={storeId!} />
  </main>
</Layout>
